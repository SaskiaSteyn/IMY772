generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

// ─── Auth models ────────────────────────────────────────────────────────────

model User {
  userID        Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  surname       String   @db.VarChar(100)
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  role          String   @default("logged_in_user") @db.VarChar(50)
  bio           String?
  interests     Json?
  education     Json?
  experience    Json?
  profile_image_data       Bytes?
  profile_image_mime_type  String?  @db.VarChar(50)
  profile_image_size_bytes Int?
  profile_image_updated_at DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("users")
}

// ─── Sample Data models ──────────────────────────────────────────────────────

model Sample {
  sample_id       String     @id @db.VarChar(255)
  collection_date DateTime?
  location_name   String?    @db.VarChar(255)
  latitude        Decimal    @db.Decimal(10, 8)
  longitude       Decimal    @db.Decimal(11, 8)
  isolation_source String?   @db.VarChar(255)
  water_temp      Decimal?   @db.Decimal(5, 2)
  ph              Decimal?   @db.Decimal(4, 2)
  tds             Decimal?   @db.Decimal(8, 2)
  do              Decimal?   @db.Decimal(8, 2)
  uploaded_by     Int?       @db.Integer
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  // Relations
  isolates            Isolate[]
  amrFindings         AmrFinding[]
  predictedPhenotypes PredictedPhenotype[]

  @@map("samples")
}

model Isolate {
  isolate_id Int     @id @default(autoincrement())
  sample_id  String  @db.VarChar(255)
  organism   String? @db.VarChar(255)
  mlst_type  String? @db.VarChar(255)

  sample Sample @relation(fields: [sample_id], references: [sample_id])

  @@index([sample_id])
  @@map("isolates")
}

model AmrFinding {
  finding_id      Int     @id @default(autoincrement())
  sample_id       String  @db.VarChar(255)
  analysis_type   String? @db.VarChar(255)
  gene_symbol     String? @db.VarChar(255)
  drug_class      String? @db.VarChar(255)
  method          String? @db.VarChar(255)
  percent_identity Decimal? @db.Decimal(5, 2)

  sample Sample @relation(fields: [sample_id], references: [sample_id])

  @@index([sample_id])
  @@map("amr_findings")
}

model PredictedPhenotype {
  phenotype_id Int     @id @default(autoincrement())
  sample_id    String  @db.VarChar(255)
  organism     String? @db.VarChar(255)
  antibiotic   String? @db.VarChar(255)
  resistant    Boolean?
  ai_resistant Boolean?
  is_manual_override Boolean @default(false)

  sample Sample @relation(fields: [sample_id], references: [sample_id])

  @@index([sample_id])
  @@map("predicted_phenotypes")
}

model AdminDeleteAudit {
  id          Int      @id @default(autoincrement())
  actorUserID Int
  actorEmail  String?  @db.VarChar(255)
  entityType  String   @db.VarChar(120)
  entityKey   Json
  reason      String   @db.Text
  created_at  DateTime @default(now())

  @@index([actorUserID])
  @@index([entityType])
  @@index([created_at])
  @@map("adminDeleteAudits")
}